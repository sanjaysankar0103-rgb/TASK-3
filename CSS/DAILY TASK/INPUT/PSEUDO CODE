H2 {
    background-color: rgb(2, 48, 32);
    color: rgb(255, 255, 255);
    padding: 50px;
    text-align: center;
}
H2:hover {
    background-color: rgb(0, 0, 0);
    color: rgb(255, 255, 255);
}

H2:focus {
    background-color: black;
    color: rgb(255, 255, 255);
}

H2:active {
    color: rgb(0, 204, 255);
}

H2:hover {
    width: 50%;
    height: 50%;
    opacity: 0.8;
}
